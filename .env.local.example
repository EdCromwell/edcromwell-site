# Rename this file to .env.local and fill in the values.
# .env.local is gitignored by default in Vite — DO NOT commit it.

# From Clerk dashboard → API Keys → "Publishable key". Safe to expose to the browser.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# The one email that's allowed into /admin. Change this if you ever move accounts.
# Falls back to edwardcromwell1998@gmail.com in code if unset, but setting it
# explicitly is safer.
VITE_ADMIN_EMAIL=edwardcromwell1998@gmail.com
